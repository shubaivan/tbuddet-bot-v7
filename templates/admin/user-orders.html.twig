{% extends 'base.html.twig' %}

{% block title %}Hello Admin!{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" type="text/css" href="{{ asset('simditor-2.3.28/styles/simditor.css') }}" />
{% endblock %}

{% block body %}
    {{ parent() }}

    <div id="ordersStatsBar" class="users-stats-bar orders-stats-bar" hidden>
        <div class="stat stat-revenue">
            <span class="stat-value" data-stat="paid_amount">₴0</span>
            <span class="stat-label">оплачено</span>
            <span class="stat-sub" data-stat="paid_count">0 замовлень</span>
        </div>
        <div class="stat stat-divider"></div>
        <div class="stat stat-pipeline new">
            <span class="stat-value" data-stat="status_new">0</span>
            <span class="stat-label">нові</span>
        </div>
        <div class="stat stat-pipeline processing">
            <span class="stat-value" data-stat="status_processing">0</span>
            <span class="stat-label">в обробці</span>
        </div>
        <div class="stat stat-pipeline shipped">
            <span class="stat-value" data-stat="status_shipped">0</span>
            <span class="stat-label">відправлено</span>
        </div>
        <div class="stat stat-pipeline delivered">
            <span class="stat-value" data-stat="status_delivered">0</span>
            <span class="stat-label">доставлено</span>
        </div>
        <div class="stat stat-pipeline cancelled">
            <span class="stat-value" data-stat="status_cancelled">0</span>
            <span class="stat-label">скасовано</span>
        </div>
        <div class="stat stat-divider"></div>
        <div class="stat stat-unpaid">
            <span class="stat-value" data-stat="unpaid_count">0</span>
            <span class="stat-label">неоплачені</span>
        </div>
    </div>

    <div class="filters-bar" style="display:flex;gap:12px;margin-bottom:15px;flex-wrap:wrap;align-items:end;">
        <div>
            <label style="font-size:13px;font-weight:600;display:block;margin-bottom:4px;">Статус замовлення</label>
            <select id="filterStatus" class="form-control form-control-sm" style="width:160px;">
                <option value="">Всі</option>
                <option value="new">Нове</option>
                <option value="processing">В обробці</option>
                <option value="shipped">Відправлено</option>
                <option value="delivered">Доставлено</option>
                <option value="cancelled">Скасовано</option>
            </select>
        </div>
        <div>
            <label style="font-size:13px;font-weight:600;display:block;margin-bottom:4px;">Оплата</label>
            <select id="filterPayment" class="form-control form-control-sm" style="width:160px;">
                <option value="">Всі</option>
                <option value="success">Оплачено</option>
                <option value="failed">Не оплачено</option>
                <option value="pending">Очікує</option>
            </select>
        </div>
        <div>
            <label style="font-size:13px;font-weight:600;display:block;margin-bottom:4px;">Джерело</label>
            <select id="filterSource" class="form-control form-control-sm" style="width:140px;">
                <option value="">Всі</option>
                <option value="tg">Telegram</option>
                <option value="web">Web</option>
            </select>
        </div>
        <div>
            <label style="font-size:13px;font-weight:600;display:block;margin-bottom:4px;">Дата від</label>
            <input type="date" id="filterDateFrom" class="form-control form-control-sm" style="width:150px;">
        </div>
        <div>
            <label style="font-size:13px;font-weight:600;display:block;margin-bottom:4px;">Дата до</label>
            <input type="date" id="filterDateTo" class="form-control form-control-sm" style="width:150px;">
        </div>
        <div style="align-self:center;">
            <label style="font-size:13px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:6px;">
                <input type="checkbox" id="filterHideUnpaid" checked>
                Сховати неоплачені
            </label>
        </div>
        <div>
            <button id="applyFilters" class="btn btn-primary btn-sm">Фільтрувати</button>
            <button id="resetFilters" class="btn btn-secondary btn-sm">Скинути</button>
        </div>
    </div>

    {% set labels = {
        'id': 'ID',
        'total_amount': 'Сума',
        'order_status': 'Статус',
        'purchase_source': 'Джерело',
        'nova_poshta_tracking_number': 'ТТН',
        'delivery_city': 'Місто',
        'delivery_department': 'Відділення',
        'liq_pay_status': 'Оплата',
        'product_info': 'Продукт',
        'c_user_info': 'Веб-користувач',
        't_user_info': 'TG-користувач',
        'created_at': 'Створено'
    } %}

    {% if th_keys|length %}
        <!-- Table -->
        <table id='telegramUserTable' class='display dataTable orders-table'>

            <thead>
            <tr>
                {% for th_key in th_keys %}
                    <th scope="col">{{ labels[th_key] ?? th_key }}</th>
                {% endfor %}
            </tr>
            </thead>
        </table>
    {% endif %}

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('index/js/user_orders.min') }}

    <script defer>
        console.log('getJSonObject');
        function getJSonObject(value) {
            return $.parseJSON(value.replace(/&quot;/ig, '"'));
        }

        let th_keys = getJSonObject("{{ dataTableKeys ? dataTableKeys|json_encode() : "{}" }}");
        let for_prepare_defs = getJSonObject("{{ dataTableKeys ? dataTableKeys|json_encode() : "{}" }}");
    </script >

    <script src="{{ asset('simditor-2.3.28/site/assets/scripts/module.js') }}" defer></script>
    <script src="{{ asset('simditor-2.3.28/site/assets/scripts/hotkeys.js') }}" defer></script>


    <script src="{{ asset('simditor-2.3.28/lib/simditor.js') }}" defer></script>


{% endblock %}

