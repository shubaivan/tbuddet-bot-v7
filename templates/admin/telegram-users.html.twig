{% extends 'base.html.twig' %}

{% block title %}Hello Admin!{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" type="text/css" href="{{ asset('simditor-2.3.28/styles/simditor.css') }}" />
{% endblock %}

{% block body %}
    {{ parent() }}

    <div class="filters-bar" style="display:flex;gap:12px;margin-bottom:15px;flex-wrap:wrap;align-items:end;">
        <div>
            <label style="font-size:13px;font-weight:600;display:block;margin-bottom:4px;">Джерело</label>
            <select id="filterSource" class="form-control form-control-sm" style="width:150px;">
                <option value="">Всі</option>
                <option value="tg">Telegram</option>
                <option value="web">Email / Web</option>
            </select>
        </div>
        <div>
            <label style="font-size:13px;font-weight:600;display:block;margin-bottom:4px;">Замовлення</label>
            <select id="filterOrders" class="form-control form-control-sm" style="width:180px;">
                <option value="">Всі користувачі</option>
                <option value="with_orders">З замовленнями</option>
                <option value="without_orders">Без замовлень</option>
            </select>
        </div>
        <div>
            <label style="font-size:13px;font-weight:600;display:block;margin-bottom:4px;">Зареєстровані від</label>
            <input type="date" id="filterRegFrom" class="form-control form-control-sm" style="width:150px;">
        </div>
        <div>
            <label style="font-size:13px;font-weight:600;display:block;margin-bottom:4px;">Зареєстровані до</label>
            <input type="date" id="filterRegTo" class="form-control form-control-sm" style="width:150px;">
        </div>
        <div>
            <button id="applyFilters" class="btn btn-primary btn-sm">Фільтрувати</button>
            <button id="resetFilters" class="btn btn-secondary btn-sm">Скинути</button>
        </div>
    </div>

    {% set labels = {
        'origin_id': 'ID',
        'user': 'Користувач',
        'phone': 'Телефон',
        'orders_summary': 'Замовлення',
        'created_at': 'Реєстрація',
        'last_visit': 'Остання активність',
        'source': 'Джерело',
        'actions': ''
    } %}

    {% if th_keys|length %}
        <table id='telegramUserTable' class='display dataTable users-table'>
            <thead>
            <tr>
                {% for th_key in th_keys %}
                    <th scope="col">{{ labels[th_key] ?? th_key }}</th>
                {% endfor %}
            </tr>
            </thead>
        </table>
    {% endif %}

    <!-- User orders modal -->
    <div class="modal fade user-orders-modal" id="userOrdersModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Замовлення користувача</h5>
                    <div class="uo-user"></div>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">&times;</button>
                </div>
                <div class="modal-body uo-body"></div>
            </div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('index/js/telegram_users.min') }}

    <script defer>
        console.log('getJSonObject');
        function getJSonObject(value) {
            return $.parseJSON(value.replace(/&quot;/ig, '"'));
        }

        let th_keys = getJSonObject("{{ dataTableKeys ? dataTableKeys|json_encode() : "{}" }}");
        let for_prepare_defs = getJSonObject("{{ dataTableKeys ? dataTableKeys|json_encode() : "{}" }}");
    </script >

    <script src="{{ asset('simditor-2.3.28/site/assets/scripts/module.js') }}" defer></script>
    <script src="{{ asset('simditor-2.3.28/site/assets/scripts/hotkeys.js') }}" defer></script>


    <script src="{{ asset('simditor-2.3.28/lib/simditor.js') }}" defer></script>


{% endblock %}

