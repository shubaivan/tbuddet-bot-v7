{% extends 'base.html.twig' %}

{% block title %}Користувач #{{ profile.id }}{% endblock %}

{% block body %}
    {{ parent() }}

    <div class="user-detail-page" style="max-width:980px;margin:0 auto;padding:20px;">
        <a href="{{ path('app_admin_users') }}" style="font-size:13px;color:#64748b;text-decoration:none;">&larr; До списку користувачів</a>

        <div class="profile-card" style="display:flex;gap:24px;align-items:flex-start;background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:20px;margin-top:12px;">
            <div style="flex:1;">
                <div style="display:flex;align-items:center;gap:12px;margin-bottom:8px;">
                    <h1 style="font-size:22px;margin:0;">{{ profile.name }}</h1>
                    {% if profile.source == 'tg' %}
                        <span class="src-pill tg"><i class="fab fa-telegram-plane"></i> Telegram</span>
                    {% else %}
                        <span class="src-pill web"><i class="fas fa-envelope"></i> Web</span>
                    {% endif %}
                </div>
                <div style="display:grid;grid-template-columns:140px 1fr;gap:6px 12px;font-size:14px;color:#475569;">
                    {% if profile.handle %}<div>Контакт</div><div><strong>{{ profile.handle }}</strong></div>{% endif %}
                    {% if profile.phone %}<div>Телефон</div><div>{{ profile.phone }}</div>{% endif %}
                    {% if profile.email %}<div>Email</div><div>{{ profile.email }}</div>{% endif %}
                    {% if profile.telegram_id %}<div>Telegram ID</div><div><code>{{ profile.telegram_id }}</code></div>{% endif %}
                    {% if profile.created_at %}<div>Реєстрація</div><div>{{ profile.created_at }}</div>{% endif %}
                    {% if profile.last_visit %}<div>Остання активність</div><div>{{ profile.last_visit }}</div>{% endif %}
                </div>
            </div>
            <div class="user-detail-stats" style="display:flex;gap:14px;">
                <div style="background:#dcfce7;color:#166534;padding:12px 16px;border-radius:8px;text-align:center;min-width:120px;">
                    <div style="font-size:22px;font-weight:700;">{{ paidCount }}</div>
                    <div style="font-size:12px;font-weight:600;">Оплачено</div>
                </div>
                <div style="background:#fef3c7;color:#92400e;padding:12px 16px;border-radius:8px;text-align:center;min-width:140px;">
                    <div style="font-size:22px;font-weight:700;font-variant-numeric:tabular-nums;">₴{{ paidSum|number_format(0, '.', ' ') }}</div>
                    <div style="font-size:12px;font-weight:600;">Сума оплачених</div>
                </div>
            </div>
        </div>

        <h2 style="margin:24px 0 12px;font-size:18px;">Замовлення ({{ orders|length }})</h2>

        {% if orders is empty %}
            <div style="background:#f8fafc;border:1px dashed #cbd5e1;padding:24px;text-align:center;border-radius:8px;color:#64748b;">
                У користувача поки немає замовлень.
            </div>
        {% else %}
            <div class="uo-list" style="display:flex;flex-direction:column;gap:6px;">
                {% for o in orders %}
                    {% set isPaid = o.liqPayStatus == 'success' %}
                    <a class="uo-row" href="{{ path('app_admin_order_detail', {id: o.id}) }}" target="_blank"
                       style="display:grid;grid-template-columns:60px 110px auto auto auto 1fr;gap:12px;align-items:center;padding:10px 12px;border:1px solid #e2e8f0;border-radius:8px;text-decoration:none;color:inherit;background:#fff;">
                        <span class="uo-id" style="font-family:ui-monospace,monospace;font-weight:600;color:#475569;">#{{ o.id }}</span>
                        <span class="uo-amount" style="font-weight:700;font-variant-numeric:tabular-nums;color:#0f172a;">₴{{ o.totalAmount|number_format(0, '.', ' ') }}</span>
                        <span class="uo-pill {{ isPaid ? 'paid' : 'pending' }}">{{ isPaid ? 'Оплачено' : 'Не оплачено' }}</span>
                        {% if o.orderStatus %}
                            <span class="order-status-pill status-{{ o.orderStatus.value }}">{{ o.orderStatus.label }}</span>
                        {% else %}
                            <span></span>
                        {% endif %}
                        {% if o.novaPoshtaTrackingNumber %}
                            <span style="font-size:12px;color:#1d4ed8;">ТТН: {{ o.novaPoshtaTrackingNumber }}</span>
                        {% else %}
                            <span></span>
                        {% endif %}
                        <span class="uo-date" style="text-align:right;font-size:12px;color:#64748b;font-variant-numeric:tabular-nums;">{{ o.createdAt|date('Y-m-d H:i') }}</span>
                    </a>
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}
