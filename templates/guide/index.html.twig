<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Інструкція — Art Beton Market</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; line-height: 1.7; color: #333; background: #f8f9fa; }
        .container { max-width: 860px; margin: 0 auto; padding: 32px 24px; background: #fff; min-height: 100vh; }
        h1 { font-size: 28px; margin-bottom: 8px; color: #1a1a1a; border-bottom: 3px solid #007bff; padding-bottom: 12px; }
        h2 { font-size: 22px; margin-top: 40px; margin-bottom: 12px; color: #1a1a1a; border-bottom: 2px solid #e9ecef; padding-bottom: 8px; }
        h3 { font-size: 18px; margin-top: 28px; margin-bottom: 8px; color: #333; }
        p { margin-bottom: 12px; }
        ul, ol { margin-bottom: 12px; padding-left: 24px; }
        li { margin-bottom: 4px; }
        table { border-collapse: collapse; width: 100%; margin-bottom: 16px; font-size: 14px; }
        th, td { border: 1px solid #dee2e6; padding: 8px 12px; text-align: left; }
        th { background: #f1f3f5; font-weight: 600; }
        code { background: #f1f3f5; padding: 2px 6px; border-radius: 4px; font-size: 13px; }
        pre { background: #f8f9fa; border: 1px solid #e9ecef; border-radius: 6px; padding: 16px; overflow-x: auto; margin-bottom: 16px; font-size: 13px; line-height: 1.5; }
        pre code { background: none; padding: 0; }
        blockquote { border-left: 4px solid #007bff; padding: 8px 16px; margin-bottom: 16px; background: #f0f7ff; color: #555; }
        a { color: #007bff; text-decoration: none; }
        a:hover { text-decoration: underline; }
        img { max-width: 100%; height: auto; border: 1px solid #dee2e6; border-radius: 6px; margin: 8px 0; }
        strong { color: #1a1a1a; }
        hr { border: none; border-top: 1px solid #e9ecef; margin: 32px 0; }
        .header-links { display: flex; gap: 16px; flex-wrap: wrap; margin: 16px 0 24px; padding: 16px; background: #e3f2fd; border-radius: 8px; }
        .header-links a { font-weight: 600; font-size: 15px; }
        @media (max-width: 600px) {
            .container { padding: 16px 12px; }
            h1 { font-size: 22px; }
            h2 { font-size: 18px; }
            table { font-size: 12px; }
            th, td { padding: 4px 8px; }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header-links">
            <a href="https://artbeton.market">🌐 Сайт</a>
            <a href="https://api.artbeton.market/admin">⚙️ Адмін-панель</a>
            <a href="https://t.me/prod_beton_decor_bot">🤖 Telegram-бот</a>
        </div>
        <div id="content"></div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script>
        const markdown = {{ markdown|json_encode|raw }};
        // Remove image references (they won't load on this page)
        const cleaned = markdown.replace(/!\[.*?\]\(img\/.*?\)/g, '');
        document.getElementById('content').innerHTML = marked.parse(cleaned);
    </script>
</body>
</html>
